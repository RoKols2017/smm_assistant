# Шаблон переменных окружения для SMM Assistant Flask app

# Flask
FLASK_ENV=production
FLASK_SECRET_KEY=change-me-to-a-long-random-secret
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
TRUST_PROXY_COUNT=1
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true

# PostgreSQL
POSTGRES_DB=sms_assistant
POSTGRES_USER=sms_assistant
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql://sms_assistant:change-me-db-password@postgres:5432/sms_assistant

# Nginx production ingress
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
APP_DOMAIN=example.com

# OpenAI API
OPENAI_API_KEY=your_openai_key

# Дополнительные настройки
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_TIMEOUT=30
VK_API_VERSION=5.139

# Модели OpenAI (опционально)
OPENAI_TEXT_MODEL=gpt-5
OPENAI_IMAGE_MODEL=dall-e-3

# Legacy script compatibility (optional for old demo scripts)
VK_TOKEN=
VK_GROUP_ID=
TG_TOKEN=
TG_CHAT_ID=
